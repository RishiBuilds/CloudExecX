# ============================================================
# CloudExecX — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All services below have free tiers.

# ── MongoDB Atlas (Free Tier — 512MB) ──────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cloudexecx?retryWrites=true&w=majority

# ── Upstash Redis (Free Tier) ──────────────────────────────
UPSTASH_REDIS_URL=rediss://default:<password>@<host>:<port>

# ── Clerk Authentication (Free Tier) ───────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Backend Configuration ─────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Worker Configuration ──────────────────────────────────
WORKER_CONCURRENCY=2

# ── Frontend (Next.js) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
